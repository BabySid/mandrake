{
  "server": {
    "listen": ":8888",
    "read_timeout": "3600s",
    "write_timeout": "3600s"
  },
  "routes": [
    {
      "path": "/",
      "upstream": "https://${host}",
      "flush_interval": -1,
      "transport": {
        "tls_skip_verify": false,
        "read_timeout": "3600s",
        "write_timeout": "3600s"
      },
      "request": {
        "headers": {
          "set": {
            "Host": "${host}",
            "User-Agent": "Go-http-client/1.1"
          },
          "delete": [
            "X-Stainless-Timeout",
            "Anthropic-Beta",
            "X-Stainless-Os",
            "X-Stainless-Retry-Count",
            "Anthropic-Dangerous-Direct-Browser-Access",
            "Anthropic-Version",
            "X-App",
            "X-Claude-Code-Session-Id",
            "X-Stainless-Runtime",
            "X-Stainless-Runtime-Version",
            "X-Stainless-Arch",
            "X-Stainless-Lang",
            "X-Stainless-Package-Version"
          ]
        },
        "body": {
          "prepend": {
            "system": {
              "type": "text",
              "text": "You are an Anthropic's official CLI for Claude."
            }
          }
        }
      },
      "response": {
        "headers": {
          "set": {},
          "delete": []
        }
      }
    }
  ],
  "log": {
    "level": "info"
  }
}
